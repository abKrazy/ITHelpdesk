# Squad: ignore runtime state (logs, inbox, sessions)
# Note: .squad/casting/* is identity and MUST be committed to main, not ignored
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# --- Azure Developer CLI (azd) ---
.azure/
# compiled Bicep artifacts
infra/**/*.json
!infra/main.parameters.json
!infra/abbreviations.json

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Node / Next.js frontend ---
frontend/node_modules/
frontend/.next/
frontend/out/

# --- Local env / secrets (never commit) ---
.env
*.local.env
