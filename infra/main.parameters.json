{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "serviceNowInstanceUrl": {
      "value": "${SERVICENOW_INSTANCE_URL=https://dev283128.service-now.com}"
    },
    "serviceNowUsername": {
      "value": "${SERVICENOW_USERNAME}"
    },
    "serviceNowPassword": {
      "value": "${SERVICENOW_PASSWORD}"
    },
    "chatModelDeploymentName": {
      "value": "${AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4}"
    },
    "chatModelName": {
      "value": "${AZURE_OPENAI_CHAT_MODEL=gpt-5.4}"
    },
    "embeddingModelDeploymentName": {
      "value": "${AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large}"
    },
    "embeddingModelName": {
      "value": "${AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large}"
    },
    "searchIndexName": {
      "value": "${AZURE_SEARCH_INDEX_NAME=it-helpdesk-kb}"
    },
    "kbContainerName": {
      "value": "${AZURE_STORAGE_KB_CONTAINER=kbdocs}"
    }
  }
}
